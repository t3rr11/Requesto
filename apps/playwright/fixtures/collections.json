[
  {
    "id": "col-test-sample-api",
    "name": "Sample API",
    "description": "Sample REST API endpoints",
    "folders": [
      {
        "id": "folder-test-users",
        "name": "Users",
        "collectionId": "col-test-sample-api"
      },
      {
        "id": "folder-test-posts",
        "name": "Posts",
        "collectionId": "col-test-sample-api"
      }
    ],
    "requests": [
      {
        "id": "req-test-get-users",
        "name": "List Users",
        "method": "GET",
        "url": "{{baseUrl}}/users",
        "headers": { "Accept": "application/json" },
        "collectionId": "col-test-sample-api",
        "folderId": "folder-test-users",
        "order": 0,
        "auth": { "type": "none" }
      },
      {
        "id": "req-test-create-user",
        "name": "Create User",
        "method": "POST",
        "url": "{{baseUrl}}/users",
        "headers": { "Content-Type": "application/json", "Accept": "application/json" },
        "body": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\"\n}",
        "collectionId": "col-test-sample-api",
        "folderId": "folder-test-users",
        "order": 1,
        "auth": { "type": "none" }
      },
      {
        "id": "req-test-get-posts",
        "name": "List Posts",
        "method": "GET",
        "url": "{{baseUrl}}/posts",
        "headers": { "Accept": "application/json" },
        "collectionId": "col-test-sample-api",
        "folderId": "folder-test-posts",
        "order": 0,
        "auth": { "type": "none" }
      }
    ]
  },
  {
    "id": "col-test-github",
    "name": "GitHub API",
    "description": "GitHub REST API v3",
    "folders": [],
    "requests": [
      {
        "id": "req-test-github-user",
        "name": "Get User",
        "method": "GET",
        "url": "https://api.github.com/users/octocat",
        "headers": { "Accept": "application/vnd.github.v3+json" },
        "collectionId": "col-test-github",
        "order": 0,
        "auth": { "type": "none" },
        "preRequestScript": "// Set a timestamp before the request runs\nenvironment.set('timestamp', new Date().toISOString());",
        "testScript": "test('status is 200', () => {\n  expect(response.status).toBe(200);\n});\n\ntest('response has login field', () => {\n  const data = response.json();\n  expect(data.login).toBeDefined();\n});\n\ntest('response time is acceptable', () => {\n  expect(response.duration).toBeLessThan(5000);\n});"
      }
    ]
  }
]
