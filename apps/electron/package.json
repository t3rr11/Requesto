{
  "name": "requesto-electron",
  "version": "1.5.10",
  "description": "Requesto - API Client",
  "homepage": "https://requesto.com.au",
  "main": "dist/main.js",
  "author": {
    "name": "Matthew Allen",
    "email": "matt@retoggle.com.au"
  },
  "license": "MIT",
  "scripts": {
    "dev": "tsc && electron .",
    "build": "tsc",
    "test": "vitest run",
    "package": "electron-builder --publish never",
    "package:win": "electron-builder --win --x64 --publish never",
    "package:mac": "electron-builder --mac --publish never",
    "package:linux": "electron-builder --linux --publish never"
  },
  "build": {
    "appId": "com.requesto.app",
    "productName": "Requesto",
    "directories": {
      "output": "../../dist"
    },
    "files": [
      "dist/**/*",
      {
        "from": "../../apps/frontend/dist",
        "to": "frontend/dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraResources": [
      {
        "from": "../../apps/backend",
        "to": "backend",
        "filter": [
          "dist/**/*",
          "data/**/*",
          "package.json",
          "package-lock.json"
        ]
      }
    ],
    "afterPack": "scripts/afterPack.js",
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "../../apps/frontend/public/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "../../apps/frontend/public/logo.png",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "../../apps/frontend/public/logo.png",
      "category": "Development"
    },
    "publish": {
      "provider": "github",
      "owner": "t3rr11",
      "repo": "Requesto"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "${productName}.Setup.${version}.${ext}"
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "electron": "41.5.0",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
