{
  "name": "requesto-electron",
  "version": "1.0.0",
  "description": "Requesto - API Client",
  "main": "dist/main.js",
  "author": "Requesto Contributors",
  "license": "MIT",
  "scripts": {
    "dev": "tsc && electron .",
    "build": "tsc",
    "package": "electron-builder",
    "package:win": "electron-builder --win --x64",
    "package:mac": "electron-builder --mac",
    "package:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.requesto.app",
    "productName": "Requesto",
    "directories": {
      "output": "../../dist"
    },
    "files": [
      "dist/**/*",
      {
        "from": "../../apps/frontend/dist",
        "to": "frontend/dist",
        "filter": ["**/*"]
      }
    ],
    "extraResources": [
      {
        "from": "../../apps/backend",
        "to": "backend",
        "filter": ["dist/**/*", "data/**/*", "package.json", "package-lock.json"]
      }
    ],
    "afterPack": "scripts/afterPack.js",
    "win": {
      "target": ["nsis", "portable"],
      "icon": "../../apps/frontend/public/icon.ico"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "../../apps/frontend/public/logo.png",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "../../apps/frontend/public/logo.png",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^24.9.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.2"
  }
}
