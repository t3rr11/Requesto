{
  "name": "requesto-backend",
  "version": "1.0.0",
  "description": "Backend API proxy for Requesto",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmit && esbuild src/server.ts --bundle --outfile=dist/server.js --platform=node --target=node20 --format=cjs",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.1",
    "axios": "^1.15.0",
    "fastify": "^5.8.5",
    "form-data": "^4.0.5",
    "node-fetch": "^3.3.2",
    "simple-git": "^3.36.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/node-fetch": "^2.6.13",
    "esbuild": "^0.27.7",
    "selfsigned": "^5.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
